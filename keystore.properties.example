# Play release signing config — copy this to `keystore.properties` and fill in
# real values. `keystore.properties` itself is gitignored, never commit it.
#
# storeFile MUST be an absolute path (or relative to project root).
# Best practice: keep the .jks OUTSIDE the repo, e.g. under
#   C:/Users/APK.TW_Tester/keystores/magnifier-release.jks
# so an accidental `rm -rf` on the worktree doesn't nuke your signing key.

storeFile=C:/Users/APK.TW_Tester/keystores/magnifier-release.jks
storePassword=REPLACE_ME
keyAlias=magnifier
keyPassword=REPLACE_ME
